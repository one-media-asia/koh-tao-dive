# Optional API base URL for frontend (leave empty for same-origin)
VITE_API_BASE_URL=

# Email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=confirmed@divinginasia.com
RESEND_BOOKING_TO_EMAIL=bookings@divinginasia.com

# Optional SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Dropbox gallery
DROPBOX_ACCESS_TOKEN=


# Existing Supabase vars can remain if you're still using Supabase auth pages
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Admin authorization (comma-separated emails).
# Set BOTH so frontend route/login checks and backend API checks agree.
# Example:
# VITE_ADMIN_EMAILS=admin@yourdomain.com
# ADMIN_EMAILS=admin@yourdomain.com
VITE_ADMIN_EMAILS=
ADMIN_EMAILS=
